    "import pandas as pd\n",
    "import tensorflow as tf\n",
    "from tensorflow.keras.applications import MobileNetV2\n",
    "from tensorflow.keras.layers import Dense, GlobalAveragePooling2D, Dropout\n",
    "from tensorflow.keras.models import Model\n",
    "from tensorflow.keras.preprocessing.image import ImageDataGenerator\n",
    "from tensorflow.keras.optimizers import Adam\n",
    "from tensorflow.keras.callbacks import EarlyStopping, ReduceLROnPlateau\n",
    "import os\n",
    "\n",
    "# 1. Define Paths\n",
    "# Update these to point to your new clean images and your CSV file\n",
    "CLEAN_IMAGES_DIR = '/kaggle/working/cleaned_images'\n",
    "CSV_PATH = '/kaggle/input/datasets/brandonleejl/fyp-hydrogel-dataset/labels.csv'\n",
    "\n",
    "# 2. Load the Labels\n",
    "df = pd.read_csv(CSV_PATH)\n",
    "# Ensure the dataframe columns are correctly named (e.g., 'filename' and 'pH')\n",
    "\n",
    "# 3. Set up the Data Generators (with basic augmentation)\n",
    "# We rescale the pixels to 0-1, which MobileNet expects\n",
    "datagen = ImageDataGenerator(\n",
    "    rescale=1./255,\n",
    "    validation_split=0.2, # Reserve 20% of data for validation\n",
    "    rotation_range=15,    # Slight rotations to make the model robust\n",
    "    horizontal_flip=True\n",
    ")\n",
    "\n",
    "# Training Dataset\n",
    "train_generator = datagen.flow_from_dataframe(\n",
    "    dataframe=df,\n",
    "    directory=CLEAN_IMAGES_DIR,\n",
    "    x_col='filename',\n",
    "    y_col='ph',\n",
    "    target_size=(224, 224), # MobileNetV2 default input size\n",
    "    batch_size=16,\n",
    "    class_mode='raw',       # 'raw' is CRITICAL for regression (predicting a continuous number)\n",
    "    subset='training'\n",
    ")\n",
    "\n",
    "# Validation Dataset\n",
    "val_generator = datagen.flow_from_dataframe(\n",
    "    dataframe=df,\n",
    "    directory=CLEAN_IMAGES_DIR,\n",
    "    x_col='filename',\n",
    "    y_col='ph',\n",
    "    target_size=(224, 224),\n",
    "    batch_size=16,\n",
    "    class_mode='raw',\n",
    "    subset='validation'\n",
    ")\n",
    "\n",
    "# 4. Build the Regression Model\n",
    "# Load MobileNetV2 without the final classification layers\n",
    "base_model = MobileNetV2(weights='imagenet', include_top=False, input_shape=(224, 224, 3))\n",
    "\n",
    "# Freeze the base model layers so we don't destroy the pre-trained weights initially\n",
    "for layer in base_model.layers:\n",
    "    layer.trainable = False\n",
    "\n",
    "# Add custom layers for our pH Regression task\n",
    "x = base_model.output\n",
    "x = GlobalAveragePooling2D()(x)\n",
    "x = Dense(128, activation='relu')(x)\n",
    "x = Dropout(0.2)(x) # Prevent overfitting\n",
    "# The final layer has 1 node and a 'linear' activation because we are predicting a single continuous value\n",
    "predictions = Dense(1, activation='linear')(x) \n",
    "\n",
    "model = Model(inputs=base_model.input, outputs=predictions)\n",
    "\n",
    "# 5. Compile the Model\n",
    "# Use Mean Squared Error (MSE) for the loss function, and track Mean Absolute Error (MAE)\n",
    "model.compile(\n",
    "    optimizer=Adam(learning_rate=0.001), \n",
    "    loss='mse', \n",
    "    metrics=['mae']\n",
    ")\n",
    "\n",
    "# 6. Callbacks to prevent over-training\n",
    "early_stop = EarlyStopping(monitor='val_loss', patience=10, restore_best_weights=True)\n",
    "reduce_lr = ReduceLROnPlateau(monitor='val_loss', factor=0.2, patience=5, min_lr=1e-6)\n",
    "\n",
    "# 7. Train the Model!\n",
    "history = model.fit(\n",
    "    train_generator,\n",
    "    validation_data=val_generator,\n",
    "    epochs=50,\n",
    "    callbacks=[early_stop, reduce_lr]\n",
    ")\n",
    "\n",
    "# 8. Save the final model in the native Keras format\n",
    "model_path = '/kaggle/working/ph_regression_model.keras'\n",
    "model.save(model_path)\n",
    "print(f\"Model training complete and safely saved to: {model_path}\")"
