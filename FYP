    "import cv2\n",
    "import numpy as np\n",
    "import os\n",
    "import glob\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# 1. Define your Kaggle paths\n",
    "INPUT_DIR = '/kaggle/input/datasets/brandonleejl/fyp-hydrogel-dataset/images' \n",
    "OUTPUT_DIR = '/kaggle/working/cleaned_images'\n",
    "\n",
    "# Create the output directory if it doesn't exist (or clear it if we are re-running)\n",
    "os.makedirs(OUTPUT_DIR, exist_ok=True)\n",
    "\n",
    "def process_single_image(image_path, filename):\n",
    "    img = cv2.imread(image_path)\n",
    "    if img is None:\n",
    "        print(f\"  -> ERROR: Could not read {filename}\")\n",
    "        return False\n",
    "    \n",
    "    # --- NEW FIX: The Digital Blackout ---\n",
    "    # We calculate 15% of the height and 25% of the width.\n",
    "    # Then we draw a pure black box over that top-left corner to erase the labels.\n",
    "    height, width = img.shape[:2]\n",
    "    cv2.rectangle(img, (0, 0), (int(width * 0.25), int(height * 0.15)), (0, 0, 0), -1)\n",
    "    # -------------------------------------\n",
    "\n",
    "    original = img.copy()\n",
    "    \n",
    "    # Convert to Grayscale to catch the overall glow\n",
    "    gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)\n",
    "\n",
    "    # Blur and Threshold\n",
    "    blurred = cv2.GaussianBlur(gray, (15, 15), 0)\n",
    "    _, thresh = cv2.threshold(blurred, 0, 255, cv2.THRESH_BINARY + cv2.THRESH_OTSU)\n",
    "\n",
    "    # Find contours\n",
    "    contours, _ = cv2.findContours(thresh, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)\n",
    "    \n",
    "    valid_contours = []\n",
    "    \n",
    "    for cnt in contours:\n",
    "        area = cv2.contourArea(cnt)\n",
    "        if area > 2000: # Keep anything bigger than random dust\n",
    "            valid_contours.append(cnt)\n",
    "\n",
    "    if len(valid_contours) == 0:\n",
    "        print(f\"  -> WARNING: No hydrogel found in {filename}. It might be too dark.\")\n",
    "\n",
    "    # Sort by size and keep the top 4 \n",
    "    valid_contours = sorted(valid_contours, key=cv2.contourArea, reverse=True)[:4]\n",
    "\n",
    "    # Create black mask and apply\n",
    "    mask = np.zeros(img.shape[:2], dtype=np.uint8)\n",
    "    cv2.drawContours(mask, valid_contours, -1, 255, thickness=cv2.FILLED)\n",
    "    clean_result = cv2.bitwise_and(original, original, mask=mask)\n",
    "\n",
    "    # Save\n",
    "    output_path = os.path.join(OUTPUT_DIR, filename)\n",
    "    cv2.imwrite(output_path, clean_result)\n",
    "    \n",
    "    return clean_result\n",
    "\n",
    "# 2. Loop through all images in the dataset (Using uppercase .PNG)\n",
    "image_files = glob.glob(os.path.join(INPUT_DIR, '*.PNG')) \n",
    "print(f\"Found {len(image_files)} images to process...\")\n",
    "\n",
    "processed_count = 0\n",
    "for filepath in image_files:\n",
    "    filename = os.path.basename(filepath)\n",
    "    success = process_single_image(filepath, filename)\n",
    "    if success is not False:\n",
    "        processed_count += 1\n",
    "\n",
    "print(f\"\\nSuccess! Cleaned and saved {processed_count} images to {OUTPUT_DIR}\")\n",
    "\n",
    "# 3. Visualize a Before & After to verify it worked perfectly\n",
    "if len(image_files) > 0:\n",
    "    sample_file = image_files[0]\n",
    "    sample_filename = os.path.basename(sample_file)\n",
    "    \n",
    "    orig_img = cv2.imread(sample_file)\n",
    "    clean_img = cv2.imread(os.path.join(OUTPUT_DIR, sample_filename))\n",
    "    \n",
    "    plt.figure(figsize=(10, 5))\n",
    "    plt.subplot(1, 2, 1)\n",
    "    plt.title(\"Original (with text & background)\")\n",
    "    plt.imshow(cv2.cvtColor(orig_img, cv2.COLOR_BGR2RGB))\n",
    "    plt.axis('off')\n",
    "    \n",
    "    plt.subplot(1, 2, 2)\n",
    "    plt.title(\"Cleaned (Pure Chemical Data)\")\n",
    "    plt.imshow(cv2.cvtColor(clean_img, cv2.COLOR_BGR2RGB))\n",
    "    plt.axis('off')\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.show()"
   ]
