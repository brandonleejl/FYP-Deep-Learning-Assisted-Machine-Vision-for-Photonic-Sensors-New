    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from sklearn.metrics import r2_score, mean_squared_error, mean_absolute_error\n",
    "from datetime import datetime\n",
    "import os\n",
    "\n",
    "# --- 1. Define MC Dropout Prediction Function ---\n",
    "def predict_mc_dropout(model, image_batch, num_samples=30):\n",
    "    # Run the model 'num_samples' times with training=True to keep Dropout active\n",
    "    predictions = [model(image_batch, training=True) for _ in range(num_samples)]\n",
    "    predictions = np.array(predictions)\n",
    "    \n",
    "    # Calculate Mean and Standard Deviation (Uncertainty)\n",
    "    mean_preds = np.mean(predictions, axis=0)\n",
    "    std_preds = np.std(predictions, axis=0)\n",
    "    return mean_preds, std_preds\n",
    "\n",
    "# --- 2. Gather Predictions ---\n",
    "true_ph_values = []\n",
    "predicted_ph_means = []\n",
    "predicted_ph_stds = []\n",
    "filenames = []\n",
    "timestamps = []\n",
    "\n",
    "print(\"Running MC Dropout evaluation on validation data...\")\n",
    "# Reset generator to start from the beginning\n",
    "val_generator.reset() \n",
    "\n",
    "# Iterate through the validation dataset\n",
    "for i in range(len(val_generator)):\n",
    "    x_batch, y_batch = val_generator[i]\n",
    "    filenames_batch = val_generator.filenames[i * val_generator.batch_size : (i+1) * val_generator.batch_size]\n",
    "    \n",
    "    mean_preds, std_preds = predict_mc_dropout(model, x_batch, num_samples=30)\n",
    "    \n",
    "    for j in range(len(y_batch)):\n",
    "        filenames.append(filenames_batch[j])\n",
    "        true_ph_values.append(y_batch[j])\n",
    "        predicted_ph_means.append(mean_preds[j][0])\n",
    "        predicted_ph_stds.append(std_preds[j][0])\n",
    "        timestamps.append(datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\"))\n",
    "        \n",
    "    if i >= len(val_generator) - 1:\n",
    "        break\n",
    "\n",
    "# --- 3. Calculate Academic Metrics ---\n",
    "r2 = r2_score(true_ph_values, predicted_ph_means)\n",
    "rmse = np.sqrt(mean_squared_error(true_ph_values, predicted_ph_means))\n",
    "mae = mean_absolute_error(true_ph_values, predicted_ph_means)\n",
    "\n",
    "print(f\"\\n--- FYP Report Metrics ---\")\n",
    "print(f\"R-squared (R²): {r2:.4f}\")\n",
    "print(f\"RMSE:           {rmse:.4f}\")\n",
    "print(f\"MAE:            {mae:.4f}\")\n",
    "\n",
    "# --- 4. Export to CSV ---\n",
    "results_df = pd.DataFrame({\n",
    "    'Timestamp': timestamps,\n",
    "    'Filename': filenames,\n",
    "    'True_pH': true_ph_values,\n",
    "    'Predicted_pH': predicted_ph_means,\n",
    "    'Uncertainty_Bound_(±)': predicted_ph_stds,\n",
    "    'Absolute_Error': np.abs(np.array(true_ph_values) - np.array(predicted_ph_means))\n",
    "})\n",
    "\n",
    "csv_path = '/kaggle/working/FYP_Model_Evaluation_Results.csv'\n",
    "results_df.to_csv(csv_path, index=False)\n",
    "print(f\"\\nDetailed CSV exported to: {csv_path}\")\n",
    "\n",
    "# --- 5. Generate Parity Plot with Error Bars ---\n",
    "plt.figure(figsize=(8, 8))\n",
    "plt.errorbar(true_ph_values, predicted_ph_means, yerr=predicted_ph_stds, fmt='o', \n",
    "             ecolor='lightgray', elinewidth=2, capsize=0, alpha=0.7, label='Predictions ± Uncertainty')\n",
    "\n",
    "# Draw the ideal y=x line\n",
