    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from sklearn.metrics import confusion_matrix, ConfusionMatrixDisplay, classification_report\n",
    "\n",
    "# 1. Load the CSV we generated earlier\n",
    "csv_path = '/kaggle/working/FYP_Model_Evaluation_Results.csv'\n",
    "df = pd.read_csv(csv_path)\n",
    "\n",
    "# 2. Convert Regression numbers into Classification Categories (Binning)\n",
    "# We round the predictions to the nearest whole number to match your True pH classes\n",
    "df['True_Category'] = df['True_pH'].round().astype(int)\n",
    "df['Predicted_Category'] = df['Predicted_pH'].round().astype(int)\n",
    "\n",
    "# Get the unique pH levels tested (e.g., [3, 4, 5, 6, 7, 8])\n",
    "labels = sorted(df['True_Category'].unique())\n",
    "\n",
    "# 3. Generate the Confusion Matrix\n",
    "cm = confusion_matrix(df['True_Category'], df['Predicted_Category'], labels=labels)\n",
    "\n",
    "# 4. Plot it beautifully for your report\n",
    "fig, ax = plt.subplots(figsize=(8, 6))\n",
    "disp = ConfusionMatrixDisplay(confusion_matrix=cm, display_labels=labels)\n",
    "disp.plot(cmap=plt.cm.Blues, ax=ax, colorbar=True)\n",
    "\n",
    "plt.title('Confusion Matrix: Predicted vs True pH Categories', fontsize=14)\n",
    "plt.xlabel('AI Predicted pH', fontsize=12)\n",
    "plt.ylabel('True Laboratory pH', fontsize=12)\n",
    "\n",
    "# Save the graph\n",
    "plt.savefig('/kaggle/working/Confusion_Matrix_FYP.png', dpi=300, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "# 5. Print the detailed Classification Report (for your False Positives/Negatives)\n",
    "print(\"\\n--- Detailed FYP Classification Report ---\")\n",
    "print(classification_report(df['True_Category'], df['Predicted_Category'], labels=labels, zero_division=0))"
   ]
