ly' \n","MODEL_PATH = '/kaggle/working/unet_gel_finder_augmented.keras'\n","OUTPUT_CSV = '/kaggle/working/Ultimate_pH_Dataset.csv'\n","\n","# --- 2. Load the AI (with compile bypass) ---\n","print(\"Loading Augmented U-Net 'Finder' model...\")\n","unet_model = tf.keras.models.load_model(MODEL_PATH, compile=False)\n","\n","# -----------------------------\n","# NEW CONFIG (safe defaults)\n","# -----------------------------\n","THRESH = 0.5\n","MAX_GELS = 4\n","\n","MIN_AREA_224 = 50          # same spirit as your old \"area < 50 continue\"\n","ERODE_KERNEL = 9\n","ERODE_ITERS = 1\n","\n","# QC metrics are computed but NOT used to filter unless you set this True\n","ENABLE_QC_FILTER = False\n","MIN_CORE_PIXELS = 200\n","MAX_SAT_PCT = 0.20\n","MAX_DARK_PCT = 0.20\n","MIN_BLUR_VAR = 30.0\n","\n","\n","def _qc_metrics(img_bgr, core_mask_full):\n","    \"\"\"Compute simple QC metrics. Returns dict.\"\"\"\n","    gray = cv2.cvtColor(img_bgr, cv2.COLOR_BGR2GRAY)\n","    blur_var = float(cv2.Laplacian(gray, cv2.CV_64F).var())\n","\n","    hsv = cv2.cvtColor(img_bgr, cv2.COLOR_BGR2HSV)\n","    v = hsv[:, :, 2]\n","\n","    core_pixels = int(np.sum(core_mask_full == 1))\n","    if core_pixels == 0:\n","        return {\"blur_var\": blur_var, \"sat_pct\": 1.0, \"dark_pct\": 1.0, \"core_pixels\": 0, \"qc_pass\": False}\n","\n","    v_core = v[core_mask_full == 1]\n","    sat_pct = float(np.mean(v_core >= 250))\n","    dark_pct = float(np.mean(v_core <= 5))\n","\n","    qc_pass = True\n","    if blur_var < MIN_BLUR_VAR: qc_pass = False\n","    if sat_pct > MAX_SAT_PCT: qc_pass = False\n","    if dark_pct > MAX_DARK_PCT: qc_pass = False\n","    if core_pixels < MIN_CORE_PIXELS: qc_pass = False\n","\n","    return {\n","        \"blur_var\": blur_var,\n","        \"sat_pct\": sat_pct,\n","        \"dark_pct\": dark_pct,\n","        \"core_pixels\": core_pixels,\n","        \"qc_pass\": qc_pass\n","    }\n","\n","\n","# --- 3. The Batch Extraction Engine (UPDATED, STILL BATCH PREDICTS) ---\n","def process_image_batch(image_paths, filenames):\n","    raw_images = []\n","    input_tensors = []\n","    valid_filenames = []\n","    \n","    for path, fname in zip(image_paths, filenames):\n","        img_raw = cv2.imread(path)\n","        if img_raw is not None:\n","            raw_images.append(img_raw)\n","            valid_filenames.append(fname)\n","            img_rgb = cv2.cvtColor(img_raw, cv2.COLOR_BGR2RGB)\n","            input_tensors.append(cv2.resize(img_rgb, (224, 224), interpolation=cv2.INTER_AREA) / 255.0)\n","            \n","    if not input_tensors:\n","        return []\n","\n","    # AI predicts the ENTIRE BATCH simultaneously\n","    batch_array = np.array(input_tensors, dtype=np.float32)\n","    pred_masks = unet_model.predict(batch_array, batch_size=len(batch_array), verbose=0)\n","    \n","    results = []\n","    \n","    for i in range(len(raw_images)):\n","        img_raw = raw_images[i]\n","        fname = valid_filenames[i]\n","        orig_h, orig_w = img_raw.shape[:2]\n","        \n","        # threshold U-Net output (224x224)\n","        mask_uint8 = (pred_masks[i, :, :, 0] > THRESH).astype(np.uint8) * 255\n","        \n","        # Find ALL contours (potential gels)\n","        contours, _ = cv2.findContours(mask_uint8, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)\n","        if not contours:\n","            continue\n","        \n","        # Filter tiny contours and keep top MAX_GELS by area\n","        contours = [c for c in contours if cv2.contourArea(c) >= MIN_AREA_224]\n","        if not contours:\n","            continue\n","        \n","        contours = sorted(contours, key=cv2.contourArea, reverse=True)[:MAX_GELS]\n","\n","        # Pre-split channels on FULL image once (fast)\n","        b, g, r = cv2.split(img_raw)\n","        h, s, v = cv2.split(cv2.cvtColor(img_raw, cv2.COLOR_BGR2HSV))\n","        l_chan, a_chan, b_chan = cv2.split(cv2.cvtColor(img_raw, cv2.COLOR_BGR2LAB))\n","        \n","        # Erosion kernel for core-mask\n","        k = cv2.getStructuringElement(cv2.MORPH_ELLIPSE, (ERODE_KERNEL, ERODE_KERNEL))\n","        \n","        # We'll compute per-gel features then aggregate across gels\n","        per_gel_feats = []\n","        per_gel_qc = []\n","        areas_full = []\n","\n","        for gel_idx, contour in enumerate(contours, start=1):\n","            area_224 = cv2.contourArea(contour)\n","            # build single-gel 224 mask (0/1)\n","            single_mask_224 = np.zeros_like(mask_uint8, dtype=np.uint8)\n","            cv2.drawContours(single_mask_224, [contour], -1, 1, thickness=cv2.FILLED)\n","\n","            # resize to full size mask (0/1)\n","            full_mask = cv2.resize(single_mask_224, (orig_w, orig_h), interpolation=cv2.INTER_NEAREST).astype(np.uint8)\n","\n","            # core mask (eroded)\n","            core_mask = cv2.erode(full_mask, k, iterations=ERODE_ITERS)\n","\n","            # QC metrics (do NOT filter unless ENABLE_QC_FILTER=True)\n","            qc = _qc_metrics(img_raw, core_mask)\n","            per_gel_qc.append(qc)\n","            if ENABLE_QC_FILTER and not qc[\"qc_pass\"]:\n","                continue\n","            \n","            # extract pixels from core region\n","            valid_g = g[core_mask == 1]\n","            valid_r = r[core_mask == 1]\n","            valid_h = h[core_mask == 1]\n","            valid_v = v[core_mask == 1]\n","            valid_a = a_chan[core_mask == 1]\n","            \n","            if valid_r.size == 0 or np.median(valid_r) == 0:\n","                continue\n","\n","            # FULL-IMAGE area of this gel (more meaningful than 224 area)\n","            area_full = float(np.sum(full_mask == 1))\n","            areas_full.append(area_full)\n","\n","            # features for this gel\n","            feat = {\n","                f'Gel{gel_idx}_Median_Green': float(np.median(valid_g)),\n","                f'Gel{gel_idx}_Median_Red': float(np.median(valid_r)),\n"," 