['imageWidth']\n","        \n","        # Create a pure black background\n","        mask = np.zeros((height, width), dtype=np.uint8)\n","        \n","        # Loop through every polygon you drew in Labelme for this image\n","        for shape in data['shapes']:\n","            # Extract the points and format them for OpenCV\n","            points = np.array(shape['points'], dtype=np.int32)\n","            # Draw the polygon and fill it with pure white (255)\n","            cv2.fillPoly(mask, [points], 255)\n","            \n","        # Create the new filename (e.g., IMG_6023.json -> IMG_6023.PNG)\n","        base_name = os.path.basename(json_file).replace('.json', '.PNG')\n","        output_path = os.path.join(OUTPUT_MASKS_DIR, base_name)\n","        \n","        # Save the new mask image\n","        cv2.imwrite(output_path, mask)\n","        converted_count += 1\n","        \n","    except Exception as e:\n","        print(f\"Error converting {os.path.basename(json_file)}: {e}\")\n","\n","print(f\"\\nSuccess! Converted {converted_count} JSON files into image masks.\")\n","print(f\"Saved to: {OUTPUT_MASKS_DIR}\")"]},{"cell_type":"code","execution_count":2,"id":"9630260e","metadata":{"_cell_guid":"b1076dfc-b9ad-4769-8c92-a6c4dae69d19","_uuid":"8f2839f25d086af736a60e9eeb907d3b93b6e0e5","execution":{"iopub.execute_input":"2026-03-07T16:05:00.063056Z","iopub.status.busy":"2026-03-07T16:05:00.062796Z","iopub.status.idle":"2026-03-07T16:09:23.414434Z","shell.execute_reply":"2026-03-07T16:09:23.413524Z"},"papermill":{"duration":263.356932,"end_time":"2026-03-07T16:09:23.415907","exception":false,"start_time":"2026-03-07T16:05:00.058975","status":"completed"},"tags":[]},"outputs":[{"name":"stderr","output_type":"stream","text":["2026-03-07 16:05:01.788191: E external/local_xla/xla/stream_executor/cuda/cuda_fft.cc:467] Unable to register cuFFT factory: Attempting to register factory for plugin cuFFT when one has already been registered\n","WARNING: All log messages before