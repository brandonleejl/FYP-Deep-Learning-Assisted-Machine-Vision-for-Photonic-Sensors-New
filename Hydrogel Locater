_model = xgb.XGBRegressor(\n","    n_estimators=1000, \n","    learning_rate=0.05, \n","    max_depth=6,\n","    random_state=42,\n","    early_stopping_rounds=50\n",")\n","\n","# Fit using the Validation set as the referee\n","xgb_model.fit(\n","    X_train, y_train,\n","    eval_set=[(X_val, y_val)],\n","    verbose=False\n",")\n","\n","print(f\"Training stopped early at tree number: {xgb_model.best_iteration}\")\n","\n","# --- 5. Professional Biosensor Metrics (Taking the Final Exam) ---\n","y_pred = xgb_model.predict(X_test)\n","\n","mae = mean_absolute_error(y_test, y_pred)\n","rmse = np.sqrt(mean_squared_error(y_test, y_pred))\n","r2 = r2_score(y_test, y_pred)\n","within_0_2 = np.mean(np.abs(y_test - y_pred) <= 0.2) * 100\n","\n","print(\"\\n--- FINAL TEST SET METRICS (XGBOOST) ---\")\n","print(f\"MAE:  {mae:.3f} pH (Average absolute error)\")\n","print(f\"RMSE: {rmse:.3f} pH (Heavily penalizes massive mistakes)\")\n","print(f\"R²:   {r2:.3f} (Variance explained)\")\n","print(f\"Biosensor Reliability (±0.2 pH): {within_0_2:.1f}%\")\n","\n","# --- 6. Export Standardized Artifacts ---\n","joblib.dump(xgb_model, '/kaggle/working/biosensor_xgboost_model.pkl')\n","\n","config = {\n","    \"model_name\": \"biosensor_xgboost_model.pkl\",\n","    \"image_target_size\": [224, 224],\n","    \"mask_threshold\": 0.5,\n","    \"features_required\": feature_names,\n","    \"expected_metrics\": {\n","        \"mae\": round(mae, 3),\n","        \"rmse\": round(rmse, 3),\n","        \"reliability_margin_0_2\": round(within_0_2, 1)\n","    }\n","}\n","\n","with open('/kaggle/working/pipeline_config_xgb.json', 'w') as f:\n","    json.dump(config, f, indent=4)\n","\n","# --- 7. Generate Thesis-Grade Visuals (Calibration + SHAP) ---\n","plt.figure(figsize=(16, 6))\n","\n","# Subplot 1: Calibration Curve\n","plt.subplot(1, 2, 1)\n","plt.scatter(y_test, y_pred, alpha=0.7, color='purple', edgecolor='k')\n","\n","min_val = min(min(y_test), min(y_pred))\n","max_val = max(max(y_test), max(y_pred))\n","plt.plot([min_val, max_val], [min_val, max_val], 'r--', lw=2, label='Perfect Prediction')\n","\n","plt.fill_between([min_val, max_val], \n","                 [min_val - 0.2, max_val - 0.2], \n","                 [min_val + 0.2, max_val + 0.2], \n","                 color='red', alpha=0.1, label='±0.2 Error Band')\n","\n","plt.title(\"XGBoost Calibration: Predicted vs True pH\")\n","plt.xlabel(\"True pH (Lab Grade)\")\n","plt.ylabel(\"Predicted pH (Biosensor)\")\n","plt.legend()\n","plt.grid(True, linestyle='--', alpha=0.6)\n","\n","# Subplot 2: SHAP Feature Importance\n","plt.subplot(1, 2, 2)\n","explainer = shap.TreeExplainer(xgb_model)\n","shap_values = explainer.shap_values(X_test)\n","\n","# SHAP creates its own plot structure, so we render it safely inside the subplot\n","shap.summary_plot(shap_values, X_test, show=False, plot_size=None)\n","plt.title(\"SHAP: What drives the AI's pH decisions?\")\n","\n","plt.tight_layout()\n","plt.show()"]},{"cell_type":"code","execution_count":11,"id":"82208c5f","metadata":{"execution":{"iopub.execute_input":"2026-03-07T15:40:42.069648Z","iopub.status.busy":"2026-03-07T15:40:42.069354Z","iopub.status.idle":"2026-03-07T15:40:42.500084Z","shell.execute_reply":"2026-03-07T15:40:42.499338Z"},"papermill":{"duration":0.536037,"end_time":"2026-03-07T15:40:42.501515","exception":false,"start_time":"2026-03-07T15:40:41.965478","status":"completed"},"tags":[]},"outputs":[{"data":{"image/png":"\n","text/plain":["<Figure size 1000x600 with 1 Axes>"]},"metadata":{},"output_type":"display_data"}],"source":["#Cell 10\n","import matplotlib.pyplot as plt\n","import seaborn as sns\n","\n","# Calculate the errors (Residuals = True pH - Predicted pH)\n","residuals = y_test - y_pred\n","\n","plt.figure(figsize=(10, 6))\n","# Scatter plot of True pH vs the Error\n","plt.scatter(y_test, residuals, alpha=0.6, color='crimson', edgecolor='k')\n","\n","# Draw the perfect \"Zero Error\" line\n","plt.axhline(y=0, color='black', linestyle=