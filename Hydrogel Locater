ust return black\n","        clean_pred_masks.append(np.zeros_like(mask_uint8))\n","\n","clean_pred_masks = np.array(clean_pred_masks)\n","# ---------------------------------------------------\n","\n","# 3. Plot the results\n","plt.figure(figsize=(12, 3 * num_samples))\n","\n","for i in range(num_samples):\n","    plt.subplot(num_samples, 3, i * 3 + 1)\n","    if i == 0: plt.title(\"Original Image\", fontsize=14, fontweight='bold')\n","    plt.imshow(test_imgs[i])\n","    plt.axis('off')\n","\n","    plt.subplot(num_samples, 3, i * 3 + 2)\n","    if i == 0: plt.title(\"Hand-Drawn Target\", fontsize=14, fontweight='bold')\n","    plt.imshow(true_masks[i, :, :, 0], cmap='gray')\n","    plt.axis('off')\n","\n","    # Now plotting the CLEANED mask!\n","    plt.subplot(num_samples, 3, i * 3 + 3)\n","    if i == 0: plt.title(\"AI Predicted Mask (Cleaned)\", fontsize=14, fontweight='bold')\n","    plt.imshow(clean_pred_masks[i], cmap='gray')\n","    plt.axis('off')\n","\n","plt.tight_layout()\n","plt.show()"]},{"cell_type":"code","execution_count":5,"id":"76b25a3c","metadata":{"execution":{"iopub.execute_input":"2026-03-07T15:34:14.936534Z","iopub.status.busy":"2026-03-07T15:34:14.936224Z","iopub.status.idle":"2026-03-07T15:37:14.266634Z","shell.execute_reply":"2026-03-07T15:37:14.265907Z"},"papermill":{"duration":179.379919,"end_time":"2026-03-07T15:37:14.268217","exception":false,"start_time":"2026-03-07T15:34:14.888298","status":"completed"},"tags":[]},"outputs":[{"name":"stdout","output_type":"stream","text":["Loading Augmented U-Net 'Finder' model...\n","Found 1344 raw images. Igniting BATCH extraction pipeline...\n"]},{"name":"stderr","output_type":"stream","text":["Processing Batches: 100%|██████████| 42/42 [02:59<00:00,  4.26s/it]"]},{"name":"stdout","output_type":"stream","text":["\n","Flawless Victory! Massive Feature Dataset saved to: /kaggle/working/Ultimate_pH_Dataset.csv\n"]},{"name":"stderr","output_type":"stream","text":["\n"]}],"source":["import os\n","imp