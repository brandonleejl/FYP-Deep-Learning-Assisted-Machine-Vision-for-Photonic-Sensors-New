ontourArea(largest_contour)\n","        if area < 50: continue \n","            \n","        clean_mask_224 = np.zeros_like(mask_uint8)\n","        cv2.drawContours(clean_mask_224, [largest_contour], -1, 1, thickness=cv2.FILLED)\n","        full_size_mask = cv2.resize(clean_mask_224, (orig_w, orig_h), interpolation=cv2.INTER_NEAREST)\n","        \n","        # --- ADVANCED COLOR SPACE EXTRACTION ---\n","        b, g, r = cv2.split(img_raw)\n","        h, s, v = cv2.split(cv2.cvtColor(img_raw, cv2.COLOR_BGR2HSV))\n","        # Lab color space perfectly mimics human eye perception of Green/Red shifts\n","        l_chan, a_chan, b_chan = cv2.split(cv2.cvtColor(img_raw, cv2.COLOR_BGR2LAB))\n","        \n","        valid_g = g[full_size_mask == 1]\n","        valid_r = r[full_size_mask == 1]\n","        valid_h = h[full_size_mask == 1]\n","        valid_v = v[full_size_mask == 1]\n","        valid_a = a_chan[full_size_mask == 1]\n","        \n","        if len(valid_r) == 0 or np.median(valid_r) == 0: continue\n","            \n","        results.append({\n","            'Filename': fname,\n","            # The Classics\n","            'Median_Green': np.median(valid_g),\n","            'Median_Red': np.median(valid_r),\n","            'Ratio_G_R': np.median(valid_g) / np.median(valid_r),\n","            'Median_Hue': np.median(valid_h),\n","            # The Advanced Metrics\n","            'Std_Green': np.std(valid_g),      # Is the dye blotchy?\n","            'Std_Red': np.std(valid_r),\n","            'Median_Lab_A': np.median(valid_a), # The ultimate Green-to-Red indicator\n","            'Median_HSV_V': np.median(valid_v), # Accounts for UV light brightness/distance\n","            'Mask_Area': area                   # Accounts for hydrogel swelling\n","        })\n","        \n","    return results\n","\n","# --- 4. Run the Pipeline in Batches ---\n","all_files = sorted(os.listdir(NEW_IMAGES_DIR))\n","image_names = [f for f in all_files if f.upper().endswith(('.P