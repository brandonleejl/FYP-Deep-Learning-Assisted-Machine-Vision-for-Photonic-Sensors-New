XACT SAME 20% test set (269 images) as the Random Forest\n","X_temp, X_test, y_temp, y_test = train_test_split(X_df, y, test_size=0.2, random_state=42)\n","\n","# Split the remaining 1073 images into Train (80%) and Validation (20%)\n","X_train, X_val, y_train, y_val = train_test_split(X_temp, y_temp, test_size=0.2, random_state=42)\n","\n","print(f\"Data Split: {len(X_train)} Train | {len(X_val)} Validation | {len(X_test)} Locked Test\")\n","\n","# --- 4. Train XGBoost with Early Stopping ---\n","# We give it 1000 tries, but if the Validation score doesn't improve for 50 rounds, it stops early!\n","xgb_model = xgb.XGBRegressor(\n","    n_estimators=1000, \n","    learning_rate=0.05, \n","    max_depth=6,\n","    random_state=42,\n","    early_stopping_rounds=50\n",")\n","\n","# Fit using the Validation set as the referee\n","xgb_model.fit(\n","    X_train, y_train,\n","    eval_set=[(X_val, y_val)],\n","    verbose=False\n",")\n","\n","print(f\"Training stopped early at tree number: {xgb_model.best_iteration}\")\n","\n","# --- 5. Professional Biosensor Metrics (Taking the Final Exam) ---\n","y_pred = xgb_model.predict(X_test)\n","\n","mae = mean_absolute_error(y_test, y_pred)\n","rmse = np.sqrt(mean_squared_error(y_test, y_pred))\n","r2 = r2_score(y_test, y_pred)\n","within_0_2 = np.mean(np.abs(y_test - y_pred) <= 0.2) * 100\n","\n","print(\"\\n--- FINAL TEST SET METRICS (XGBOOST) ---\")\n","print(f\"MAE:  {mae:.3f} pH (Average absolute error)\")\n","print(f\"RMSE: {rmse:.3f} pH (Heavily penalizes massive mistakes)\")\n","print(f\"R²:   {r2:.3f} (Variance explained)\")\n","print(f\"Biosensor Reliability (±0.2 pH): {within_0_2:.1f}%\")\n","\n","# --- 6. Export Standardized Artifacts ---\n","joblib.dump(xgb_model, '/kaggle/working/biosensor_xgboost_model.pkl')\n","\n","config = {\n","    \"model_name\": \"biosensor_xgboost_model.pkl\",\n","    \"image_target_size\": [224, 224],\n","    \"mask_threshold\": 0.5,\n","    \"features_required\": feature_names,\n","    \"expected_metrics\": {\n","        \"mae\": round(mae, 3),\n","        \"rmse\": round(rmse, 3),\n","        \"reliability_margin_0_2\": round(within_0_2, 1)\n","    }\n","}\n","\n","with open('/kaggle/working/pipeline_config_xgb.json', 'w') as f:\n","    json.dump(config, f, indent=4)\n","\n","# --- 7. Generate Thesis-Grade Visuals (Calibration + SHAP) ---\n","plt.figure(figsize=(16, 6))\n","\n","# Subplot 1: Calibration Curve\n","plt.subplot(1, 2, 1)\n","plt.scatter(y_test, y_pred, alpha=0.7, color='purple', edgecolor='k')\n","\n","min_val = min(min(y_test), min(y_pred))\n","max_val = max(max(y_test), max(y_pred))\n","plt.plot([min_val, max_val], [min_val, max_val], 'r--', lw=2, label='Perfect Prediction')\n","\n","plt.fill_between([min_val, max_val], \n","                 [min_val - 0.2, max_val - 0.2], \n","                 [min_val + 0.2, max_val + 0.2], \n","                 color='red', alpha=0.1, label='±0.2 Error Band')\n","\n","plt.title(\"XGBoost Calibration: Predicted vs True pH\")\n","plt.xlabel(\"True pH (Lab Grade)\")\n","plt.ylabel(\"Predicted pH (Biosensor)\")\n","plt.legend()\n","plt.grid(True, linestyle='--', alpha=0.6)\n","\n","# Subplot 2: SHAP Feature Importance\n","plt.subplot(1, 2, 2)\n","explainer = shap.TreeExplainer(xgb_model)\n","shap_values = explainer.shap_values(X_test)\n","\n","# SHAP creates its own plot structure, so we render it safely inside the subplot\n","shap.summary_plot(shap_values, X_test, show=False, plot_size=None)\n","plt.title(\"SHAP: What drives the AI's pH decisions?\")\n","\n","plt.tight_layout()\n","plt.show()"]},{"cell_type":"code","execution_count":11,"id":"34573cb3","metadata":{"execution":{"iopub.execute_input":"2026-03-07T16:17:05.728633Z","iopub.status.busy":"2026-03-07T16:17:05.727932Z","iopub.status.idle":"2026-03-07T16:17:06.154519Z","shell.execute_reply":"2026-03-07T16:17:06.153889Z"},"papermill":{"duration":0.528595,"end_time":"2026-03-07T16:17:06.156567","exception":false,"start_time":"2026-03-07T16:17:05.6