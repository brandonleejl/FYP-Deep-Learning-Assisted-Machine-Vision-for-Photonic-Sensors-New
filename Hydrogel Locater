kaggle/working/unet_gel_finder_augmented.keras'\n","OUTPUT_CSV = '/kaggle/working/Ultimate_pH_Dataset.csv'\n","\n","# --- 2. Load the Trained AI (WITH COMPILE=FALSE FIX) ---\n","print(\"Loading Augmented U-Net 'Finder' model...\")\n","unet_model = tf.keras.models.load_model(MODEL_PATH, compile=False)\n","\n","# --- 3. The Extraction Engine (with Filter & HSV) ---\n","def extract_chemistry(image_path, filename):\n","    img_raw = cv2.imread(image_path)\n","    if img_raw is None:\n","        return None\n","    \n","    orig_h, orig_w = img_raw.shape[:2]\n","    \n","    # Resize for the AI\n","    img_rgb = cv2.cvtColor(img_raw, cv2.COLOR_BGR2RGB)\n","    img_resized = cv2.resize(img_rgb, (224, 224))\n","    input_tensor = np.expand_dims(img_resized / 255.0, axis=0)\n","    \n","    # AI predicts the mask\n","    pred_mask = unet_model.predict(input_tensor, verbose=0)[0]\n","    mask_uint8 = (np.where(pred_mask > 0.5, 1.0, 0.0) * 255).astype(np.uint8)[:, :, 0]\n","    \n","    # --- POST-PROCESSING: The Largest Blob Filter ---\n","    contours, _ = cv2.findContours(mask_uint8, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)\n","    if not contours:\n","        return None # AI found absolutely nothing\n","        \n","    largest_contour = max(contours, key=cv2.contourArea)\n","    clean_mask_224 = np.zeros_like(mask_uint8)\n","    cv2.drawContours(clean_mask_224, [largest_contour], -1, 1, thickness=cv2.FILLED)\n","    \n","    # Upscale the clean mask back to the massive original photo size\n","    full_size_mask = cv2.resize(clean_mask_224, (orig_w, orig_h), interpolation=cv2.INTER_NEAREST)\n","    \n","    # --- CHEMISTRY EXTRACTION: RGB & HSV ---\n","    blue, green, red = cv2.split(img_raw)\n","    \n","    # Extract HSV (Note: OpenCV Hue goes from 0 to 179, not 360)\n","    img_hsv = cv2.cvtColor(img_raw, cv2.COLOR_BGR2HSV)\n","    hue, sat, val = cv2.split(img_hsv)\n","    \n","    # Isolate only the pixels inside our clean AI mask\n","    valid_green = green[full_size_mask == 1]\n","    valid_red = red[full_size_mask == 1]\n","    valid_hue = hue[full_size_mask == 1]\n","    \n","    if len(valid_red) == 0:\n","        return None\n","        \n","    # Calculate the medians (This deletes the UV glare!)\n","    median_g = np.median(valid_green)\n","    median_r = np.median(valid_red)\n","    median_h = np.median(valid_hue)\n","    \n","    if median_r == 0:\n","        return None\n","        \n","    ratio = median_g / median_r\n","    \n","    return {\n","        'Filename': filename,\n","        'Median_Green_FITC': median_g,\n","        'Median_Red_R6G': median_r,\n","        'Green_Red_Ratio': ratio,\n","        'Median_Hue_Angle': median_h  # <--- The Hue feature!\n","    }\n","\n","# --- 4. Run the Mass Pipeline ---\n","all_files = sorted(os.listdir(NEW_IMAGES_DIR))\n","image_names = [f for f in all_files if f.upper().endswith(('.PNG', '.JPG', '.JPEG'))]\n","\n","print(f\"Found {len(image_names)} raw images. Igniting extraction pipeline...\")\n","\n","results = []\n","for img_name in tqdm(image_names, desc=\"Processing Images\"):\n","    img_path = os.path.join(NEW_IMAGES_DIR, img_name)\n","    data = extract_chemistry(img_path, img_name)\n","    if data:\n","        results.append(data)\n","\n","# --- 5. Export ---\n","df = pd.DataFrame(results)\n","df.to_csv(OUTPUT_CSV, index=False)\n","print(f\"\\nExtracted chemical data saved to: {OUTPUT_CSV}\")"]},{"cell_type":"code","execution_count":7,"id":"1cf89762","metadata":{"execution":{"iopub.execute_input":"2026-03-07T15:40:35.034188Z","iopub.status.busy":"2026-03-07T15:40:35.033427Z","iopub.status.idle":"2026-03-07T15:40:35.053956Z","shell.execute_reply":"2026-03-07T15:40:35.053074Z"},"papermill":{"duration":0.118087,"end_time":"2026-03-07T15:40:35.055466","exception":false,"start_time":"2026-03-07T15:40:34.937379","status":"completed"},"tags":[]},"outputs":[{"name":"stdout","output_type":"stream","text":["--- AI Extracted Chemical Ratios ---\n","       Filename  Med